# Application
APP_NAME=RadioManager
DEBUG=false
WORKERS=4
ENVIRONMENT=production

# Database
DATABASE_MODE=mysql
DATABASE_URL=mysql+pymysql://radiomanager:password123@localhost:3306/radiomanager
SQLALCHEMY_ECHO=false

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:7777

# Redis
REDIS_URL=redis://localhost:6379

# Admin account (created on first init)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_EMAIL=admin@radiomanager.local

# Test account (local/dev mode only)
ENABLE_TEST_ACCOUNT=false
TEST_ACCOUNT_USERNAME=admin
TEST_ACCOUNT_PASSWORD=admin123
TEST_ACCOUNT_EMAIL=admin@radiomanager.dev

# QRZ API
QRZ_USERNAME=
QRZ_PASSWORD=

# GitHub
GITHUB_TOKEN=

# SMTP (placeholder, not yet implemented)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@radiomanager.local

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# File Upload
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=uploads

