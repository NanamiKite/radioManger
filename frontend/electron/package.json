{
  "name": "radiomanager",
  "version": "2.1.0",
  "description": "RadioManager - Amateur Radio QSO Log Management System",
  "main": "electron/main.js",
  "homepage": "https://github.com/NanamiKite/radioManger",
  "author": {
    "name": "Nanami Kite",
    "email": "nanami@radiomanager.dev"
  },
  "license": "MIT",
  "scripts": {
    "electron": "electron .",
    "electron-dev": "electron . --debug",
    "electron-build": "electron-builder"
  },
  "build": {
    "appId": "com.radiomanager.app",
    "productName": "RadioManager",
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "linux": {
      "category": "HamRadio"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  }
}
