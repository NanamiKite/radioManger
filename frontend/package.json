{
  "name": "radiomanager-frontend",
  "private": true,
  "version": "1.0.0",
  "main": "./electron/main.js",
  "description": "Amateur Radio QSO Log Management System - Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "electron": "electron .",
    "electron-dev": "vite && electron .",
    "electron-build": "vite build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.4",
    "date-fns": "^2.30.0",
    "element-plus": "^2.4.4",
    "js-cookie": "^3.0.5",
    "pinia": "^2.1.7",
    "vue": "^3.3.8",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.4.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "npm-run-all": "^4.1.5",
    "sass": "^1.69.5",
    "typescript": "~5.3.0",
    "vite": "^5.0.2",
    "vue-tsc": "^1.8.22"
  }
}
