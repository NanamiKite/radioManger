{
  "name": "radiomanager-frontend",
  "private": true,
  "version": "2.1.0",
  "main": "./electron/main.js",
  "description": "RadioManager - Amateur Radio QSO Log Management System",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "electron": "electron .",
    "electron-dev": "vite build && electron .",
    "electron:win": "vite build && electron-builder --win",
    "electron:win-portable": "vite build && electron-builder --win portable",
    "electron:linux": "vite build && electron-builder --linux",
    "electron:mac": "vite build && electron-builder --mac",
    "android:init": "npx cap init RadioManager com.radiomanager.app && npx cap add android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "vite build && npx cap sync android && cd android && ./gradlew assembleDebug"
  },
  "build": {
    "appId": "com.radiomanager.app",
    "productName": "RadioManager",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "portable": {
      "artifactName": "RadioManager-${version}-portable.exe"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "axios": "^1.6.4",
    "date-fns": "^2.30.0",
    "element-plus": "^2.4.4",
    "js-cookie": "^3.0.5",
    "pinia": "^2.1.7",
    "vue": "^3.3.8",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@types/node": "^20.10.6",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.4.0",
    "capacitor-resources": "^2.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "npm-run-all": "^4.1.5",
    "sass": "^1.69.5",
    "typescript": "~5.3.0",
    "vite": "^5.0.2",
    "vue-tsc": "^1.8.22"
  }
}
